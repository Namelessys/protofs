local ut = require("UT")

local FACES = 2
local CELLS = 2

local SUBSTANCES = {
	water = 20,
	salt = 10,
}

--local portion = {.5, .5}

local cells = {}


--===== init =====--
for c = 1, CELLS do
	local cellMassTotal = 0
	
	cells[c] = {
		substances = {},
		faces = {},
	}
	
	for i, s in pairs(SUBSTANCES) do
		cells[c].substances[i] = s
		cellMassTotal = cellMassTotal + s
	end
	
	for f = 1, FACES do
		cells[c].faces[f] = {
			portion = 1 / FACES,	
		}
	end
end


